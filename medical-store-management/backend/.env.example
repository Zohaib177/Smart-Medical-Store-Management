PORT=5000
NODE_ENV=development
API_PREFIX=/api

DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=medical_store_db
DB_CONNECTION_LIMIT=10

CLIENT_URLS=http://localhost:5173,http://localhost:5174
JWT_SECRET=medical-store-dev-secret
JWT_REFRESH_SECRET=medical-store-dev-refresh-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
BCRYPT_SALT_ROUNDS=12
DEFAULT_ADMIN_EMAIL=admin@medicalstore.local
DEFAULT_ADMIN_PASSWORD=Admin@1234
DEFAULT_ADMIN_NAME=System Administrator
DEFAULT_ADMIN_PHONE=0000000000
